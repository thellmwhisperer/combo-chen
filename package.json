{
  "name": "combo-chen",
  "version": "0.1.0-bash-v1",
  "description": "Combo Chen bash five-agent chain v1 integration line (Launcher\u2192Coder\u21c4Reviewer\u2192Gate\u2192Cleaner).",
  "type": "module",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "lint:sh": "shellcheck --severity=warning --exclude=SC2154,SC2034 -s sh bin/cb-*.sh",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude='.worktrees/**' --exclude='.tmp/**' --exclude='e2e/**'",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "smol-toml": "^1.3.0"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.44.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "jscpd": "^5.0.11",
    "prettier": "^3.9.4",
    "tsdown": "^0.21.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.0.0"
  },
  "files": [
    "bin",
    "docs",
    "LICENSE",
    "README.md",
    "AGENTS.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thellmwhisperer/combo-chen"
