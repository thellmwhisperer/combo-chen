{
  "name": "combo-chen",
  "version": "0.0.57",
  "description": "Conductor for autonomous issue → PR pipelines: fixed roles, configurable agents.",
  "type": "module",
  "packageManager": "pnpm@9.12.3",
  "bin": {
    "combo-chen": "dist/cli.mjs"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "release:assets": "pnpm build && node dist/release-assets.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude='.worktrees/**' --exclude='.tmp/**'",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "smol-toml": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.21.0",
    "typescript": "^5.8.0",
    "vitest": "^4.0.0"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thellmwhisperer/combo-chen"
  },
  "license": "MIT"
}
